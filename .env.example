# ---------------------------------------------------------------------------
# ClickBank Connector MCP — environment configuration
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored and
# must NEVER be committed. In production, set these as secrets on your host
# (Railway / Render / Fly.io), NOT in the code.
# ---------------------------------------------------------------------------

# REQUIRED. Your ClickBank Clerk API key with the "Analytics" role, created in
# ClickBank > Settings > My Account > API Management.
# This is a SECRET. Paste it here (in your editor) or into your host's secrets
# manager. Never paste it into a chat, never hardcode it, never commit it.
CLICKBANK_CLERK_KEY=

# OPTIONAL. The ClickBank Developer key. Since Aug 2023 ClickBank no longer
# requires a real developer key, so this defaults to ClickBank's public
# "captain" DEV key. Only override if ClickBank issues you a specific one.
CLICKBANK_DEV_KEY=DEV-123456789012345678901234567890123456

# OPTIONAL. Default ClickBank account nickname (your seller/vendor nickname,
# e.g. the "Social Status" account nickname). If set, tools can omit the
# account_nickname argument and fall back to this.
CLICKBANK_ACCOUNT_NICKNAME=

# OPTIONAL. Account role used for analytics queries. Sellers should use
# "vendor" (the default) for the fullest sales/subscription detail.
# Valid values: vendor | affiliate
CLICKBANK_ROLE=vendor

# OPTIONAL. Default analytics breakdown dimension for get_sales_analytics.
# "PRODUCT" gives a per-product breakdown (useful to isolate UTS from other
# offers on the account) plus the account totals. See README for other values.
CLICKBANK_ANALYTICS_DIMENSION=PRODUCT

# OPTIONAL but STRONGLY RECOMMENDED for a public deployment. If set, the MCP
# endpoint requires callers (Claude) to send `Authorization: Bearer <token>`.
# Generate a long random string. You will enter this in Claude's connector
# "Advanced settings". If left blank, the endpoint is open to anyone with the
# URL — only acceptable for local testing.
MCP_AUTH_TOKEN=

# OPTIONAL. Port to listen on. Hosts like Railway/Render set PORT automatically.
PORT=3000
